# ====================== BETTAFISH Configuration ======================
# BETTAFISH host address, e.g., 0.0.0.0 or 127.0.0.1
HOST=0.0.0.0
# BETTAFISH port, default is 5000
PORT=5000

# ====================== Database Configuration ======================
# Database host, e.g., localhost or 127.0.0.1
DB_HOST=your_db_host
# Database port number, default is 3306
DB_PORT=3306
# Database username
DB_USER=your_db_user
# Database password
DB_PASSWORD=your_db_password
# Database name
DB_NAME=your_db_name
# Database charset, utf8mb4 recommended for emoji support
DB_CHARSET=utf8mb4
# Database type: mysql or postgresql
DB_DIALECT=postgresql

# ======================= LLM Configuration =======================
# You can change the API used by each LLM section. Any OpenAI-compatible request format works - just define KEY, BASE_URL and MODEL_NAME.
# Important: We strongly recommend using the recommended configuration first, get it working, then make your changes!
# Our LLM model API sponsor: https://aihubmix.com/?aff=8Ds9, providing comprehensive model APIs

# Insight Agent (Recommended: kimi-k2, official: https://platform.moonshot.cn/)
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=
INSIGHT_ENGINE_MODEL_NAME=

# Media Agent (Recommended: gemini-2.5-pro, proxy: https://aihubmix.com/?aff=8Ds9)
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=
MEDIA_ENGINE_MODEL_NAME=

# Query Agent (Recommended: deepseek-chat, official: https://platform.deepseek.com/)
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=
QUERY_ENGINE_MODEL_NAME=

# Report Agent (Recommended: gemini-2.5-pro, proxy: https://aihubmix.com/?aff=8Ds9)
# Note: Report Agent requires relatively strong model capabilities. If the final report has blank charts/abnormal paragraphs, try a stronger model
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=
REPORT_ENGINE_MODEL_NAME=

# MindSpider Agent (Recommended: deepseek-chat, official: https://platform.deepseek.com/)
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=
MINDSPIDER_MODEL_NAME=

# Forum Host (Recommended: qwen-plus, official: https://www.aliyun.com/product/bailian)
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SQL Keyword Optimizer (Recommended: qwen-plus, official: https://www.aliyun.com/product/bailian)
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# ================== Network Tools Configuration ====================
# Tavily API key for Tavily web search, apply at: https://www.tavily.com/
TAVILY_API_KEY=

# Web search tool type, supports BochaAPI or AnspireAPI, default is AnspireAPI
SEARCH_TOOL_TYPE=AnspireAPI

# Anspire AI Search API (Apply at: https://open.anspire.cn/?share_code=3E1FUOUH, half the cost of Bocha for same effect)
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=

# Bocha AI Search API (For Bocha multimodal search, despite the key name being "Web Search", it actually requires AI Search key, apply at: https://open.bochaai.com/)
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=